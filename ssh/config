Host *
  AddKeysToAgent yes
  ServerAliveInterval 60

Host github.com
  IdentityFile ~/.ssh/id_rsa_github
  IdentitiesOnly yes
Host bitbucket.org
  IdentityFile ~/.ssh/id_rsa_bb
  IdentitiesOnly yes
Host heroku.com
  IdentityFile ~/.ssh/id_rsa_heroku
  IdentitiesOnly yes
Host android-controller
  User android-controller
  HostName android-controller
  IdentityFile ~/.ssh/android-host-private-key
  IdentitiesOnly yes
Host android-staging android-host1 android-host2 android-host3 android-host4 android-host5
  User android-host
  HostName %h
  IdentityFile ~/.ssh/android-host-private-key
  IdentitiesOnly yes
