sfb=store com.microsoft.office.lync15
onenote=store com.microsoft.office.onenote
sharepoint=store com.microsoft.sharepoint
office=store com.microsoft.office.officehubrow

drops=echo \\appvfile07\Private\Intune\AndroidMAM\develop && echo \\appvfile07\Private\Intune\AndroidSSP\develop
mamdev=explorer \\appvfile07\Private\Intune\AndroidMAM\develop
