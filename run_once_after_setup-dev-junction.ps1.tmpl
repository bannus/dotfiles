{{ if ne .chezmoi.os "windows" -}}
exit 0
{{ else -}}
$devTarget = "C:\Developer\bavander"
$wsSource = {{ joinPath .chezmoi.sourceDir "windows-shell" | quote }}

# Check if junction already exists and points to the correct location
if (Test-Path $devTarget) {
    $item = Get-Item $devTarget -Force
    if ($item.LinkType -eq "Junction") {
        $resolvedTarget = (Get-Item $devTarget -Force).Target | ForEach-Object { [IO.Path]::GetFullPath($_) }
        $expectedPath = [IO.Path]::GetFullPath($wsSource)
        if ($resolvedTarget -contains $expectedPath) {
            Write-Host "Junction $devTarget already points to $wsSource"
            exit 0
        }
    }
    # Wrong target or not a junction — prompt before replacing
    $existing = if ($item.LinkType) { "$($item.LinkType) -> $($item.Target)" } else { "directory/file" }
    Write-Host "$devTarget exists as $existing"
    Write-Host "Expected junction to $wsSource"
    $answer = Read-Host "Replace it? [y/N]"
    if ($answer -notmatch '^y(es)?$') {
        Write-Host "Skipping — aliases.ps1 may not be found at $devTarget"
        exit 0
    }
    Remove-Item $devTarget -Recurse -Force
}

# Create parent directory if needed
$parent = Split-Path $devTarget -Parent
if (-not (Test-Path $parent)) {
    New-Item -ItemType Directory -Path $parent -Force | Out-Null
}

# Create junction (no special privileges required)
cmd /c mklink /J $devTarget $wsSource
Write-Host "Created junction $devTarget -> $wsSource"
{{ end -}}
