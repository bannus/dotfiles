#!/usr/bin/env node
var fs = require('fs')
  , path = require('path')
  , exec = require('child_process').exec
  , readline = require('readline')
  , sh
  , isWorkMachine = false

// Normalize HOME environment variable.
process.env.HOME = process.env.HOME || process.env.HOMEDRIVE + process.env.HOMEPATH
if (!process.env.HOME) {
  console.error(
    'No HOME environment variables available. Dotfiles cannot be installed.'
  )
  process.exit(1)
}

// Handle ~ as Bash does.
function aTarget(file) {
  return path.normalize(file.replace(/~/g, process.env.HOME))
}

// Absolute source file paths.
function aSource(file) {
  return path.resolve(__dirname, file)
}

// HOME-relative source file paths
function rSource(file) {
  return path.relative(process.env.HOME, aSource(file))
}

// CWD-relative source file paths
function lSource(file) {
  return path.relative(process.cwd(), aSource(file))
}

// Detects the complete list of file paths that should be included or linked.
function detectSources(file) {
  var sources = []

  if (sh.test('-f', aSource(file))) {
    sources.push(file)
  }

  if (sh.test('-f', aSource(file + '_' + process.platform))) {
    sources.push(file + '_' + process.platform)
  }

  return sources
}

// Call each function in the given array in order. Each function is given
// a function that, when called, calls the next function in the list.
function step(arr) {
  if (!arr.length) {
    return
  }

  arr[0](function () {
    step(arr.slice(1))
  })
}

step([
  // Install our dependencies if necessary, calling `callback` upon successful
  // completion.
  function bootstrap(callback) {
    try {
      sh = require('shelljs')
      return callback()
    } catch (e) {}

    exec('npm install --no-bin-links', {
      cwd: __dirname
    }, function (err) {
      if (err) {
        console.error('Failed to install shelljs.')
        console.error('Error:', err.message)
        process.exit(1)
      }

      sh = require('shelljs')
      return callback()
    })
  },
  // Ask whether this is a work machine to determine optional installs.
  function askWorkMachine(callback) {
    var rl = readline.createInterface({ input: process.stdin, output: process.stdout })
    rl.question('Is this a work machine? [y/N] ', function (answer) {
      rl.close()
      isWorkMachine = /^y(es)?$/i.test(answer.trim())
      callback()
    })
  },
  // Set up the C:\Developer\bavander junction (Windows only).
  // If a stale directory or wrong junction exists, prompt the user to replace it.
  function setupDevJunction(callback) {
    if (process.platform !== 'win32') return callback()

    var devTarget = 'C:\\Developer\\bavander'
    var wsSource = aSource('windows-shell')

    if (sh.test('-e', devTarget) || sh.test('-L', devTarget)) {
      // Already a correct junction — nothing to do
      try {
        var stat = fs.lstatSync(devTarget)
        if (stat.isSymbolicLink()) {
          var linkTarget = fs.readlinkSync(devTarget)
          if (path.resolve(linkTarget) === path.resolve(wsSource)) {
            return callback()
          }
        }
      } catch (e) {}

      // Exists but is wrong (stale directory or incorrect junction)
      var rl = readline.createInterface({ input: process.stdin, output: process.stdout })
      rl.question(
        devTarget + ' exists but is not a junction to\n  ' + wsSource + '\nReplace it? [y/N] ',
        function (answer) {
          rl.close()
          if (/^y(es)?$/i.test(answer.trim())) {
            sh.rm('-rf', devTarget)
            sh.mkdir('-p', path.dirname(devTarget))
            sh.exec('cmd /c mklink /J "' + devTarget + '" "' + wsSource + '"')
          } else {
            console.log('Skipping junction — aliases.ps1 may not be found at ' + devTarget)
          }
          callback()
        }
      )
    } else {
      sh.mkdir('-p', path.dirname(devTarget))
      sh.exec('cmd /c mklink /J "' + devTarget + '" "' + wsSource + '"')
      callback()
    }
  },
  // Link all the dotfiles, and install all the things.
  function install() {
    // Bash
    sh.rm('-f', aTarget('~/.bashrc'))
    detectSources('bash/.bashrc')
      .reduce(function (str, file) {
        return str + 'source ~/' + rSource(file) + '\n'
      }, '')
      // bashrc doesn't like backslashes
      .replace(/\\/g, "\/")
      .to(aTarget('~/.bashrc'))

    // Git
    sh.rm('-f', aTarget('~/.gitconfig'))
    detectSources('git/.gitconfig')
      .reduce(function (str, file) {
        return str + '[include]\n  path = ' + rSource(file) + '\n'
      }, '')
      // Git for Windows doesn't like backslashes
      .replace(/\\/g, "\/")
      .to(aTarget('~/.gitconfig'))

    // SSH
    sh.mkdir('-p', aTarget('~/.ssh'))
    sh.ln('-f', lSource('ssh/config'), aTarget('~/.ssh/config'))

    // Vim
    // get 'source <vimrc>' line
    vimrcSource = detectSources('vim/.vimrc')
      .reduce(function (str, file) {
        return str + 'source ~/' + rSource(file) + '\n'
      }, '')
      // vimrc doesn't like backslashes either
      .replace(/\\/g, "\/")
    // write to .vimrc (unix)
    sh.rm('-f', aTarget('~/.vimrc'))
    vimrcSource.to(aTarget('~/.vimrc'))
    // write to _vimrc (windows)
    sh.rm('-f', aTarget('~/_vimrc'))
    vimrcSource.to(aTarget('~/_vimrc'))
    // write to _ideavimrc (IdeaVim plugin)
    sh.rm('-f', aTarget('~/_ideavimrc'))
    detectSources('vim/.ideavimrc')
      .reduce(function (str, file) {
        return str + 'source ~/' + rSource(file) + '\n'
      }, '')
      // vimrc doesn't like backslashes either
      .replace(/\\/g, "\/")
      .to(aTarget('~/_ideavimrc'))
    // symlink .vim (unix) and vimfiles (windows)
    sh.ln('-sf', lSource('vim'), aTarget('~/vimfiles'))
    sh.ln('-sf', lSource('vim'), aTarget('~/.vim'))

    // iTerm
    if (process.platform === 'darwin') {
      sh.ln('-f', lSource('iterm/config.plist'), aTarget('~/.iterm/com.googlecode.iterm2.plist'))
    }

    // Copilot CLI
    sh.mkdir('-p', aTarget('~/.copilot'))
    sh.ln('-f', lSource('copilot/copilot-instructions.md'), aTarget('~/.copilot/copilot-instructions.md'))

    // EditorConfig
    sh.ln('-f', lSource('.editorconfig'), aTarget('~/.editorconfig'))

    // Windows shell junction is handled by the setupDevJunction step above.
    
    // Windows Terminal (Windows only)
    if (process.platform === 'win32') {
      var wtStoreDir = path.join(process.env.LOCALAPPDATA, 'Packages', 'Microsoft.WindowsTerminal_8wekyb3d8bbwe', 'LocalState')
      var wtDir = sh.test('-d', wtStoreDir)
        ? wtStoreDir
        : path.join(process.env.LOCALAPPDATA, 'Microsoft', 'Windows Terminal')
      sh.mkdir('-p', wtDir)

      var settings = JSON.parse(fs.readFileSync(aSource('windows-terminal/settings.json'), 'utf8'))

      if (isWorkMachine) {
        var workDir = aSource('windows-terminal/fragments/work')
        var priorityOrder = ['MAM', 'MDM', 'AWT', 'AST', 'Core']
        var priorityProfiles = []
        var otherProfiles = []
        fs.readdirSync(workDir)
          .filter(function (file) { return file.endsWith('.json') })
          .forEach(function (file) {
            var profile = JSON.parse(fs.readFileSync(path.join(workDir, file), 'utf8')).profiles[0]
            var startDir = profile && profile.startingDirectory
            if (startDir) {
              startDir = startDir.replace(/%([^%]+)%/g, function (_, k) {
                return process.env[k] || ('%' + k + '%')
              })
            }
            if (startDir && sh.test('-d', startDir)) {
              if (priorityOrder.indexOf(profile.name) !== -1) {
                priorityProfiles.push(profile)
              } else {
                otherProfiles.push(profile)
              }
            }
          })

        priorityProfiles.sort(function (a, b) {
          return priorityOrder.indexOf(a.name) - priorityOrder.indexOf(b.name)
        })

        settings.profiles.list = priorityProfiles.concat(settings.profiles.list).concat(otherProfiles)
      }

      fs.writeFileSync(path.join(wtDir, 'settings.json'), JSON.stringify(settings, null, 4))
    }
  }
])
